# Ignore Python cache and compiled files
__pycache__/
*.pyc
*.pyo
*.pyd

# Ignore Jupyter notebook checkpoints (if any)
.ipynb_checkpoints/

# Ignore datasets (large files)
data/*.csv
data/*.xlsx
data/*.json

# Ignore results if too large (but keep plots if needed)
results/*.pkl
results/*.json

# Ignore virtual environment folders
venv/
env/
.venv/

# Ignore OS-specific files
.DS_Store
Thumbs.db

# Ignore IDE settings
.vscode/
.idea/

# Ignore logs
*.log
